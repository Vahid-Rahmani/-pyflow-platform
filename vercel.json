{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput --ignore=*.map",
  "outputDirectory": "staticfiles",
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30,
      "includeFiles": "staticfiles/**"
    }
  },
  "routes": [
    { "src": "/static/(.*)", "dest": "/staticfiles/$1" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/accounts/(.*)", "dest": "api/index.py" },
    { "src": "/admin/(.*)", "dest": "api/index.py" },
    { "src": "/.*", "dest": "api/index.py" }
  ],
  "installCommand": "pip install -r requirements.txt"
}
