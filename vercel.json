{
  "buildCommand": "DJANGO_SETTINGS_MODULE=vercel_build python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/admin/(.*)", "dest": "/api/index.py" },
    { "src": "/accounts/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
